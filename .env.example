# =============================================================================
# myGo XML/JSON API — credentials et endpoint
# Test UI: https://admin.mygo.co/Postman/index.html
# =============================================================================
MYGO_API_BASE_URL=https://admin.mygo.co/api/hotel
MYGO_LOGIN=
MYGO_PASSWORD=

# Optionnel — réglages robustesse client myGo
MYGO_TIMEOUT_MS=8000
MYGO_MAX_RETRIES=3
MYGO_STATIC_TTL_SECONDS=86400
MYGO_SEARCH_TTL_SECONDS=300

# =============================================================================
# Supabase (Postgres + Auth + Storage)
# =============================================================================
# Pooler URL (port 6543) — pour l'app Next.js (Edge / Vercel)
# Format : postgres://postgres.<project-ref>:<password>@aws-0-eu-west-2.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Connexion directe (port 5432) — pour drizzle-kit migrations
# Format : postgres://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_DIRECT_URL=

# Supabase JS SDK (côté client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role (côté serveur uniquement, jamais exposé au client)
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# Paiement — SPS Monétique Tunisie (Sprint 2)
# =============================================================================
SPS_MERCHANT_ID=
SPS_TERMINAL_ID=
SPS_SECRET_KEY=
SPS_HMAC_KEY=
# 'sandbox' ou 'production'
SPS_ENVIRONMENT=sandbox
SPS_RETURN_URL=
SPS_NOTIFY_URL=

# =============================================================================
# Paiement — Stripe (Sprint 2)
# =============================================================================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# =============================================================================
# Twilio SMS (à remplir à l'itération 7 — module Transferts)
# =============================================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# =============================================================================
# Upstash Redis — cache distribué + rate limiting multi-pod
# Créer une base sur https://console.upstash.com → Redis → Create database
# =============================================================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# =============================================================================
# Rate limiting (fallback in-memory si Upstash absent)
# =============================================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# =============================================================================
# Sentry (optionnel — npm install @sentry/nextjs pour activer)
# =============================================================================
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# =============================================================================
# Playwright E2E — credentials de test (non requis en CI si mocks)
# =============================================================================
E2E_TEST_EMAIL=test@example.com
E2E_TEST_PASSWORD=password123
PLAYWRIGHT_BASE_URL=http://localhost:3000

# =============================================================================
# Module Vols (Amadeus / Sabre — stub si absent)
# =============================================================================
FLIGHTS_API_KEY=
FLIGHTS_API_BASE_URL=https://api.amadeus.com/v2
# FLIGHTS_DEMO_MODE=true   # Forcer le mode fixtures sans API

# =============================================================================
# Feature Flags (optionnel — fallback sur valeurs statiques dans le code)
# =============================================================================
FEATURE_HOTELS_TUNISIE=true
FEATURE_HOTELS_MONDE=false
FEATURE_VOLS=false
FEATURE_OMRA=true
FEATURE_PACKAGES=true
FEATURE_TRANSFERTS=true
FEATURE_CAR=false
FEATURE_YIELD_ENGINE=true
FEATURE_INVENTORY_LOCKS=true
FEATURE_WALLET_B2B=true

# =============================================================================
# Zitouna Pay (paiement local TN — stub si absent)
# =============================================================================
ZITOUNA_PAY_API_KEY=
ZITOUNA_PAY_MERCHANT_ID=
ZITOUNA_PAY_BASE_URL=https://api.zitounapay.tn/v1

# =============================================================================
# Email transactionnel — Resend
# https://resend.com → API Keys
# =============================================================================
RESEND_API_KEY=

# =============================================================================
# Inngest (background jobs / event-driven workflows)
# https://app.inngest.com → Settings → Signing Key
# =============================================================================
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=

# =============================================================================
# Observability / SRE
# =============================================================================
# Secret pour le health endpoint détaillé (/api/health)
# curl /api/health -H "X-Health-Secret: $HEALTH_SECRET"
HEALTH_SECRET=changeme-use-random-64-chars

# Niveau de log : debug | info | warn | error (défaut: info en prod)
LOG_LEVEL=info

# =============================================================================
# Cron — protection routes /api/cron/*
# Générer avec : openssl rand -hex 32
# =============================================================================
CRON_SECRET=changeme-use-random-64-chars

# =============================================================================
# App
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
